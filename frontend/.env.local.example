NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# Optional: backend API base URL for "Delete account" (auth delete). Leave empty when frontend and API are same origin (e.g. Vercel).
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Required for "Delete account" backend (server-only, never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_here
SUPABASE_JWT_SECRET=your_jwt_secret_here
