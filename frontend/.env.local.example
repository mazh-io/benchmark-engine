NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# Server-only Supabase (never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_here

# Lemon Squeezy billing (server-only)
LEMONSQUEEZY_API_KEY=your_ls_api_key_here
LEMONSQUEEZY_WEBHOOK_SECRET=your_ls_webhook_signing_secret_here
LEMONSQUEEZY_STORE_ID=your_ls_store_id_here
LEMONSQUEEZY_VARIANT_ID=your_ls_pro_monthly_variant_id_here

# Public label shown on the "Get Pro" CTA button (safe for browser)
NEXT_PUBLIC_PRO_LABEL=Pro — €19/mo
